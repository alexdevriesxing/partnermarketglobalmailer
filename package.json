{
  "name": "partnermarket-global-mailer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare-native audience management and compliant bulk email application.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && wrangler deploy --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cf:types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260716.1",
    "typescript": "7.0.2",
    "wrangler": "4.111.0"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3"
  }
}
